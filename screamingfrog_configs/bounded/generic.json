  "service_patterns": ["/services?(/|$)", "/solutions?(/|$)", "/treatments?(/|$)", "/repairs?(/|$)", "/installations?(/|$)"],
  "location_patterns": ["/locations?(/|$)", "/suburbs?(/|$)", "/areas?(/|$)", "/service-areas?(/|$)", "/cities?(/|$)"]
