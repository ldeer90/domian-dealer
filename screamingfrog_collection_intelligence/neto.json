{
  "family": "neto",
  "page_type": "collection",
  "collection_detection": [
    { "type": "url_regex", "value": "/(category|categories|collections)(/|$)", "confidence": 84 },
    { "type": "schema_type", "value": "CollectionPage", "confidence": 74 }
  ],
  "fields": {},
  "title_rules": {
    "default_exact": [
      "{term}",
      "{term} | {site}",
      "{term} - {site}"
    ],
    "default_like": [
      "{term} | {brand}",
      "{term}: {site}"
    ],
    "term_plus_site": [
      "{term} | {site}"
    ],
    "safe_customised": [
      "Shop {term} Online | {site}",
      "{term} Range | {site}"
    ]
  }
}
