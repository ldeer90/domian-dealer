{
  "family": "bigcommerce",
  "page_type": "collection",
  "collection_detection": [
    { "type": "url_regex", "value": "/categories?(/|$)", "confidence": 88 },
    { "type": "schema_type", "value": "CollectionPage", "confidence": 82 }
  ],
  "fields": {},
  "title_rules": {
    "default_exact": [
      "{term}",
      "{term} | {site}",
      "{term} - {site}"
    ],
    "default_like": [
      "{term} | {brand}",
      "{term}: {site}",
      "{term} category | {site}"
    ],
    "term_plus_site": [
      "{term} | {site}"
    ],
    "safe_customised": [
      "Shop {term} Online | {site}",
      "Buy {term} Online | {site}",
      "{term} Collection | {site}"
    ]
  }
}
